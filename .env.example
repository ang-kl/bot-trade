# Copy this file to .env.local (gitignored) and fill in the values for
# local development. For Vercel previews / production, set the same
# variables in the Vercel dashboard under Settings → Environment Variables
# — the deployed site never sees your local .env files.
#
# Never commit .env or .env.local. The .gitignore already blocks them.

# cTrader Open API — register an app at https://openapi.ctrader.com and
# paste the client credentials Spotware issues. The client secret must
# stay server-side (api/ctrader.js reads these via process.env; they are
# never bundled into the frontend).
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=

# Anthropic API — used by api/rundown.js and api/chat.js. Get a key at
# https://console.anthropic.com/settings/keys. Also server-side only.
ANTHROPIC_API_KEY=
